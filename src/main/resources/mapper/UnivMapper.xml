<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soldesk.mapper.UnivMapper">
    <resultMap id="univResultMap" type="com.soldesk.vo.UnivVO">
        <id property="dept_id" column="dept_id" />
        <result property="univ_name" column="univ_name" />
        <result property="dept_name" column="dept_name" />
    </resultMap>

    <!-- 모든 대학 이름, 정보 -->
    <select id="getAllUniv" resultMap="univResultMap">
        SELECT distinct univ_name, dept_id, dept_name FROM univ_department;
    </select>

</mapper>