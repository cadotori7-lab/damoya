<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soldesk.mapper.ProjectMapper">
    <resultMap id="projectResultMap" type="com.soldesk.vo.ProjectVO">
        <id column="project_id" property="projectId"/>
        <result column="owner_id" property="ownerId"/>
        <result column="title" property="title"/>
        <result column="category" property="category"/>
        <result column="summary" property="summary"/>
        <result column="capacity" property="capacity"/>
        <result column="target_grade" property="targetGrade"/>
        <result column="start_date" property="startDate"/>  
        <result column="end_date" property="endDate"/>      
        <result column="status" property="status"/>
        <result column="is_public" property="isPublic"/>
        <result column="created_at" property="createdAt"/>
        <result column="match_scope" property="matchScope"/>
        <result column="tags" property="tags"/>
        <result column="favorit_count" property="favoriteCount"/>
        <result column="view_count" property="viewCount"/>
    </resultMap>

    <!-- 프로젝트 등록-->
    <insert id="insertProject" parameterType="com.soldesk.vo.ProjectVO" 
            useGeneratedKeys="true" keyProperty="projectId">
        insert into project (owner_id, title, category, summary, capacity, target_grade, status,  match_scope, tags, end_date)
        values (#{ownerId}, #{title}, #{category}, #{summary}, #{capacity}, #{targetGrade}, #{status}, #{matchScope}, #{tags}, #{endDate})
    </insert>

    <!-- 프로젝트 전체 목록 조회-->
    <select id="getAllProjects" resultMap="projectResultMap">
        select * from project order by created_at desc
    </select>

    <!-- 프로잭트 상세 조회-->
     <select id="getProjectById" parameterType="long" resultMap="projectResultMap" >
        select *
        from project 
        where project_id = #{projectId}
     </select>

    <!-- 프로젝트 모집 수정-->
     <update id="updateProject" parameterType="com.soldesk.vo.ProjectVO">
        update project
        set title = #{title},
            category = #{category},
            match_scope = #{matchScope},
            summary = #{summary},
            capacity = #{capacity},
            target_grade = #{targetGrade},
            status = #{status},
            tags = #{tags},
            end_date = #{endDate}

        where project_id = #{projectId}
     </update>

    <!-- 프로젝트 모집 삭제-->
     <delete id="deleteProject" parameterType="long">
        delete from project
        where project_id = #{projectId}
     </delete>



</mapper>