<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soldesk.mapper.MeetingMapper">

    <resultMap id="meetingResultMap" type="com.soldesk.vo.MeetingVO">
        <id property="meeting_id" column="meeting_id" />
        <result property="project_id" column="project_id" />
        <result property="title" column="title" />
        <result property="meet_date" column="meet_date" />
        <result property="summary" column="summary" />
        <result property="content" column="content" />
    </resultMap>

    <!-- 회의록 등록 -->
    <insert id="insertMeeting" parameterType="com.soldesk.vo.MeetingVO">
        INSERT INTO meeting (project_id, title, meet_date, summary, content)
        VALUES (#{project_id}, #{title}, #{meet_date}, #{summary}, #{content})
    </insert>
    <!-- 회의록 수정 -->
    <update id="updateMeeting" parameterType="com.soldesk.vo.MeetingVO">
        UPDATE meeting
        SET title = #{title},
            meet_date = #{meet_date},
            summary = #{summary},
            content = #{content}
        WHERE meeting_id = #{meeting_id}
    </update>
    <!-- 회의록 삭제 -->
    <delete id="deleteMeeting" parameterType="long">
        DELETE FROM meeting WHERE meeting_id = #{meeting_id}
    </delete>

    <!-- 회의록 조회 -->
    <select id="selectMeetingsByProjectId" parameterType="long" resultMap="meetingResultMap">
        SELECT * FROM meeting WHERE project_id = #{project_id} ORDER BY meet_date DESC
    </select>

    <!-- 특정 회의록 조회 -->
    <select id="selectMeetingById" parameterType="long" resultMap="meetingResultMap">
        SELECT * FROM meeting WHERE meeting_id = #{meeting_id}
    </select>
</mapper>