OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=30

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001

# 챗봇 사이트 안내용 Spring 프론트 주소
SITE_BASE_URL=http://localhost:8080/damoya

# Spring과 같은 Elasticsearch 서버를 사용
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_SITE_INDEX=damoya-site-pages-rag2
ELASTICSEARCH_MENTOR_INDEX=damoya-mentors
# 보안 설정을 켠 경우에만 입력
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# 기본값: FastAPI(8001)에 함께 마운트된 사이트 검색 MCP 서버
MCP_SITE_SEARCH_URL=http://127.0.0.1:8001/mcp/site-search/mcp
MCP_MENTOR_RECOMMENDATION_URL=http://127.0.0.1:8001/mcp/mentor-recommendation/mcp
MCP_CLIENT_TIMEOUT_SECONDS=90

# 검색 MCP 서버를 별도 프로세스로 실행할 때 사용
MCP_SITE_SEARCH_HOST=127.0.0.1
MCP_SITE_SEARCH_PORT=8002
MCP_MENTOR_RECOMMENDATION_HOST=127.0.0.1
MCP_MENTOR_RECOMMENDATION_PORT=8003
